{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sion Client",
  "version": "0.1.0",
  "identifier": "com.sion.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "cef-dist/*.dll": "./",
      "cef-dist/*.pak": "./",
      "cef-dist/*.dat": "./",
      "cef-dist/*.bin": "./",
      "cef-dist/*.json": "./",
      "cef-dist/locales/*": "./locales/"
    }
  }
}
